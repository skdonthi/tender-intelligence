# PostgreSQL with pgvector
# Use a managed instance (Neon, Supabase, or local Docker):
#   docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 pgvector/pgvector:pg16
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/patterno_demo

# Anthropic — for Claude structured extraction + RAG answering
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — for text-embedding-3-small (1536 dims)
OPENAI_API_KEY=sk-ant-...
# Cohere — for rerank-v3.5 cross-encoder (optional but recommended)
# Get a free key at https://dashboard.cohere.com
# Without this, retrieval falls back to hybrid scores only
COHERE_API_KEY=...

PORT=3000

# CORS — comma-separated list of allowed origins for the API
# Set this when the dashboard is hosted separately (e.g. GitHub Pages)
# Leave as * for local development
ALLOWED_ORIGINS=*
